<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<VBox spacing="18.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="controllers.TasksKanbanController">
    <padding>
        <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
    </padding>

    <HBox alignment="CENTER_LEFT">
        <VBox spacing="4.0">
            <Label styleClass="title" text="Tasks Kanban" />
            <Label fx:id="subtitleLabel" styleClass="subtitle" text="Tasks across all projects" />
        </VBox>
        <Region HBox.hgrow="ALWAYS" />
        <Button onAction="#onBackToTasks" styleClass="btn-secondary" text="Tasks List">
            <graphic>
                <FontIcon iconLiteral="mdi2f-format-list-bulleted" iconSize="16" />
            </graphic>
        </Button>
    </HBox>

    <HBox spacing="14.0" styleClass="kanban-board" VBox.vgrow="ALWAYS">
        <VBox maxWidth="Infinity" minWidth="260" prefWidth="0.0" spacing="10" styleClass="kanban-column" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" styleClass="kanban-column-header">
                <Label maxWidth="Infinity" styleClass="kanban-column-title" text="To Do" HBox.hgrow="ALWAYS" />
                <Label fx:id="todoCountLabel" styleClass="kanban-column-count" text="0" />
            </HBox>
            <ScrollPane fx:id="todoScrollPane" fitToWidth="true" hbarPolicy="NEVER" styleClass="kanban-column-scroll" VBox.vgrow="ALWAYS">
                <VBox fx:id="todoColumn" fillWidth="true" maxWidth="Infinity" spacing="10" styleClass="kanban-column-list" VBox.vgrow="ALWAYS" />
            </ScrollPane>
        </VBox>

        <VBox maxWidth="Infinity" minWidth="260" prefWidth="0.0" spacing="10" styleClass="kanban-column" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" styleClass="kanban-column-header">
                <Label maxWidth="Infinity" styleClass="kanban-column-title" text="In Progress" HBox.hgrow="ALWAYS" />
                <Label fx:id="inProgressCountLabel" styleClass="kanban-column-count" text="0" />
            </HBox>
            <ScrollPane fx:id="inProgressScrollPane" fitToWidth="true" hbarPolicy="NEVER" styleClass="kanban-column-scroll" VBox.vgrow="ALWAYS">
                <VBox fx:id="inProgressColumn" fillWidth="true" maxWidth="Infinity" spacing="10" styleClass="kanban-column-list" VBox.vgrow="ALWAYS" />
            </ScrollPane>
        </VBox>

        <VBox maxWidth="Infinity" minWidth="260" prefWidth="0.0" spacing="10" styleClass="kanban-column" HBox.hgrow="ALWAYS">
            <HBox alignment="CENTER_LEFT" styleClass="kanban-column-header">
                <Label maxWidth="Infinity" styleClass="kanban-column-title" text="Done" HBox.hgrow="ALWAYS" />
                <Label fx:id="doneCountLabel" styleClass="kanban-column-count" text="0" />
            </HBox>
            <ScrollPane fx:id="doneScrollPane" fitToWidth="true" hbarPolicy="NEVER" styleClass="kanban-column-scroll" VBox.vgrow="ALWAYS">
                <VBox fx:id="doneColumn" fillWidth="true" maxWidth="Infinity" spacing="10" styleClass="kanban-column-list" VBox.vgrow="ALWAYS" />
            </ScrollPane>
        </VBox>
    </HBox>
</VBox>
