<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.geometry.Insets?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.formation_quiz_result.ClientQuizCardController"
      spacing="18"
      prefWidth="540"
      maxWidth="540"
      style="
        -fx-background-color:white;
        -fx-background-radius:16;
        -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.12), 20, 0.25, 0, 6);
      ">

    <padding>
        <Insets top="20" right="20" bottom="20" left="20"/>
    </padding>

    <!-- HEADER -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-padding:0 0 6 0; -fx-border-color:transparent transparent #e5e7eb transparent; -fx-border-width:0 0 1 0;">

        <Label text="Question"
               style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#4338ca;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <Label text="Choisissez une réponse"
               style="-fx-text-fill:#6b7280; -fx-font-size:12px;"/>
    </HBox>

    <!-- QUESTION TEXT -->
    <Label fx:id="questionLabel"
           wrapText="true"
           style="-fx-font-size:15px; -fx-text-fill:#1f2937; -fx-font-weight:bold;"/>

    <!-- IMAGE -->
    <StackPane fx:id="imageContainer"
               style="
                 -fx-background-color:#f3f4f8;
                 -fx-background-radius:12;
               ">

        <ImageView fx:id="quizImage"
                   fitWidth="500"
                   fitHeight="250"
                   preserveRatio="false"
                   smooth="true"
                   visible="false"/>

        <Pane style="
            -fx-background-color:linear-gradient(to top, rgba(0,0,0,0.25), transparent);
            -fx-background-radius:12;
        "/>

    </StackPane>

    <!-- ANSWERS -->
    <VBox spacing="12">

        <!-- A -->
        <HBox spacing="12"
              alignment="CENTER_LEFT"
              style="
                -fx-background-color:#f8f9ff;
                -fx-background-radius:12;
                -fx-padding:10;
              ">

            <Label text="A"
                   style="
                    -fx-background-color:#6d5dfc;
                    -fx-text-fill:white;
                    -fx-font-weight:bold;
                    -fx-alignment:center;
                    -fx-min-width:28;
                    -fx-min-height:28;
                    -fx-background-radius:20;
                   "/>

            <Button fx:id="a1"
                    wrapText="true"
                    style="
                      -fx-background-color:transparent;
                      -fx-text-fill:#1f2937;
                      -fx-font-size:13px;
                      -fx-alignment:baseline-left;
                      -fx-cursor:hand;
                    "/>
        </HBox>

        <!-- B -->
        <HBox spacing="12"
              alignment="CENTER_LEFT"
              style="
                -fx-background-color:#f8f9ff;
                -fx-background-radius:12;
                -fx-padding:10;
              ">

            <Label text="B"
                   style="
                    -fx-background-color:#6d5dfc;
                    -fx-text-fill:white;
                    -fx-font-weight:bold;
                    -fx-alignment:center;
                    -fx-min-width:28;
                    -fx-min-height:28;
                    -fx-background-radius:20;
                   "/>

            <Button fx:id="a2"
                    wrapText="true"
                    style="
                      -fx-background-color:transparent;
                      -fx-text-fill:#1f2937;
                      -fx-font-size:13px;
                      -fx-alignment:baseline-left;
                      -fx-cursor:hand;
                    "/>
        </HBox>

        <!-- C -->
        <HBox spacing="12"
              alignment="CENTER_LEFT"
              style="
                -fx-background-color:#f8f9ff;
                -fx-background-radius:12;
                -fx-padding:10;
              ">

            <Label text="C"
                   style="
                    -fx-background-color:#6d5dfc;
                    -fx-text-fill:white;
                    -fx-font-weight:bold;
                    -fx-alignment:center;
                    -fx-min-width:28;
                    -fx-min-height:28;
                    -fx-background-radius:20;
                   "/>

            <Button fx:id="a3"
                    wrapText="true"
                    style="
                      -fx-background-color:transparent;
                      -fx-text-fill:#1f2937;
                      -fx-font-size:13px;
                      -fx-alignment:baseline-left;
                      -fx-cursor:hand;
                    "/>
        </HBox>

    </VBox>

</VBox>