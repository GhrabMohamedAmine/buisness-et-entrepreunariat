<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.media.MediaView?>
<?import javafx.geometry.Insets?>

<ScrollPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="controllers.formation_quiz_result.ClientFormationDetailsController"
            fitToWidth="true"
            style="-fx-background:#eef0f6; -fx-background-color:#eef0f6;">

    <content>
        <VBox spacing="22"
              style="-fx-background-color:linear-gradient(to bottom,#f8f9ff,#eef0f6);">

            <padding>
                <Insets top="22" right="22" bottom="30" left="22"/>
            </padding>

            <!-- HEADER -->
            <VBox spacing="6">

                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Label text="Langue :"
                           style="-fx-font-weight:bold; -fx-text-fill:#374151;"/>

                    <ComboBox fx:id="langCombo"
                              prefWidth="140"
                              style="
                                -fx-background-color:white;
                                -fx-background-radius:8;
                                -fx-border-color:#d1d5db;
                                -fx-border-radius:8;
                              "/>
                </HBox>

                <Label fx:id="titreLabel"
                       style="-fx-font-size:26px; -fx-font-weight:bold; -fx-text-fill:#3b2f6b;"/>

                <Label fx:id="descLabel"
                       wrapText="true"
                       style="-fx-font-size:13px; -fx-text-fill:#6b7280;"/>

            </VBox>

            <!-- VIDEO SECTION -->
            <HBox spacing="18">

                <!-- VIDEO PLAYER CARD -->
                <VBox spacing="10"
                      style="
                        -fx-background-color:white;
                        -fx-background-radius:14;
                        -fx-padding:14;
                        -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.10), 18, 0.25, 0, 5);
                      ">

                    <StackPane style="
                        -fx-background-color:black;
                        -fx-background-radius:12;
                        -fx-padding:6;
                    ">
                        <MediaView fx:id="mainVideo"
                                   fitWidth="720"
                                   fitHeight="405"
                                   preserveRatio="true"/>
                    </StackPane>

                    <!-- PLAYER CONTROLS -->
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          style="
                            -fx-background-color:#f3f4f8;
                            -fx-background-radius:10;
                            -fx-padding:10;
                          ">

                        <Button fx:id="playBtn"
                                text="▶"
                                style="
                                  -fx-background-color:#6d5dfc;
                                  -fx-text-fill:white;
                                  -fx-background-radius:8;
                                  -fx-font-weight:bold;
                                  -fx-cursor:hand;
                                "/>

                        <Button fx:id="pauseBtn"
                                text="⏸"
                                style="
                                  -fx-background-color:#6d5dfc;
                                  -fx-text-fill:white;
                                  -fx-background-radius:8;
                                  -fx-font-weight:bold;
                                  -fx-cursor:hand;
                                "/>

                        <Button fx:id="stopBtn"
                                text="⏹"
                                style="
                                  -fx-background-color:#ef4444;
                                  -fx-text-fill:white;
                                  -fx-background-radius:8;
                                  -fx-font-weight:bold;
                                  -fx-cursor:hand;
                                "/>

                        <Slider fx:id="progressSlider" prefWidth="420"/>

                        <Label fx:id="timeLabel"
                               text="00:00 / 00:00"
                               style="-fx-text-fill:#374151; -fx-font-weight:bold;"/>

                    </HBox>
                </VBox>

                <!-- PLAYLIST -->
                <VBox spacing="12" prefWidth="260"
                      style="
                        -fx-background-color:white;
                        -fx-background-radius:14;
                        -fx-padding:14;
                        -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.10), 18, 0.25, 0, 5);
                      ">

                    <Label text="Chapitres"
                           style="-fx-font-size:16px; -fx-font-weight:bold; -fx-text-fill:#4338ca;"/>

                    <Button fx:id="video1Btn" text="Chapitre 1"
                            style="-fx-background-color:#f3f4f8; -fx-background-radius:8; -fx-cursor:hand;"/>

                    <Button fx:id="video2Btn" text="Chapitre 2"
                            style="-fx-background-color:#f3f4f8; -fx-background-radius:8; -fx-cursor:hand;"/>

                    <Button fx:id="video3Btn" text="Chapitre 3"
                            style="-fx-background-color:#f3f4f8; -fx-background-radius:8; -fx-cursor:hand;"/>

                </VBox>

            </HBox>

            <!-- QUIZ -->
            <VBox spacing="10"
                  style="
                    -fx-background-color:white;
                    -fx-background-radius:14;
                    -fx-padding:18;
                    -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.10), 18, 0.25, 0, 5);
                  ">
             <HBox style="-fx-background-color:#FFFFFF;
                      -fx-text-fill:white;
                      -fx-font-size:14px;
                      -fx-font-weight:bold;
                      -fx-background-radius:10;
                      -fx-padding:10 20;
                      -fx-cursor:hand;">
                 <Label text="Quiz de validation"
                        style="-fx-font-size:18px; -fx-font-weight:bold; -fx-text-fill:#4338ca;"/>
                 <Region HBox.hgrow="ALWAYS"/>
                <Button text="Valider le quiz"
                        onAction="#submitQuiz"
                        style="
                      -fx-background-color:#6d5dfc;
                      -fx-text-fill:white;
                      -fx-font-size:14px;
                      -fx-font-weight:bold;
                      -fx-background-radius:10;
                      -fx-padding:10 20;
                      -fx-cursor:hand;
                    "/>

             </HBox>
                <VBox fx:id="quizBox" spacing="18">
                    <Label text="test"/>
                </VBox>



            </VBox>


        </VBox>
    </content>
</ScrollPane>