<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="controllers.formation_quiz_result.QuizCardController"
      spacing="12"
      fx:id="root"
      prefWidth="300"
      style="
        -fx-background-color:white;
        -fx-background-radius:14;
        -fx-padding:14;
        -fx-effect:dropshadow(gaussian, rgba(0,0,0,0.10), 16, 0.25, 0, 5);
      ">

    <!-- HEADER QUESTION -->
    <VBox spacing="6" >

        <Label text="QUIZ"
               style="
                -fx-background-color:#6d5dfc;
                -fx-text-fill:white;
                -fx-font-weight:bold;
                -fx-padding:4 10;
                -fx-background-radius:20;
                -fx-alignment:center;
                -fx-max-width:80;
               "/>

        <Label fx:id="questionLabel"
               wrapText="true"
               style="
                -fx-font-size:15px;
                -fx-font-weight:bold;
                -fx-text-fill:#2e2e3a;
               "/>
    </VBox>

    <!-- IMAGE CONTAINER -->
    <StackPane fx:id="imageContainer"
               style="
                 -fx-background-color:#f1f2f7;
                 -fx-background-radius:10;
                 -fx-padding:0;
               ">

        <ImageView fx:id="quizImage"
                   fitWidth="280"
                   fitHeight="160"
                   preserveRatio="false"
                   smooth="true"
                   visible="false"/>

        <!-- overlay gradient -->
        <Pane style="
            -fx-background-color: linear-gradient(to top, rgba(0,0,0,0.25), transparent);
            -fx-background-radius:10;
        "/>

    </StackPane>

    <!-- ANSWERS -->
    <VBox spacing="8" >

        <Label fx:id="r1"
               wrapText="true"
               style="
                 -fx-background-color:#f3f4f8;
                 -fx-padding:8 10;
                 -fx-background-radius:8;
                 -fx-text-fill:#374151;
               "/>

        <Label fx:id="r2"
               wrapText="true"
               style="
                 -fx-background-color:#f3f4f8;
                 -fx-padding:8 10;
                 -fx-background-radius:8;
                 -fx-text-fill:#374151;
               "/>

        <Label fx:id="r3"
               wrapText="true"
               style="
                 -fx-background-color:#f3f4f8;
                 -fx-padding:8 10;
                 -fx-background-radius:8;
                 -fx-text-fill:#374151;
               "/>

    </VBox>

    <!-- ACTIONS -->
    <HBox spacing="10" alignment="CENTER_RIGHT">

        <Button fx:id="editBtn"
                text="Modifier"
                style="
                  -fx-background-color:#6d5dfc;
                  -fx-text-fill:white;
                  -fx-font-weight:bold;
                  -fx-background-radius:8;
                  -fx-padding:6 14;
                  -fx-cursor:hand;
                "/>

        <Button fx:id="deleteBtn"
                text="Supprimer"
                style="
                  -fx-background-color:#ef4444;
                  -fx-text-fill:white;
                  -fx-font-weight:bold;
                  -fx-background-radius:8;
                  -fx-padding:6 14;
                  -fx-cursor:hand;
                "/>

    </HBox>

</VBox>